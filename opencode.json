{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-gemini-auth@latest", "@mohak34/opencode-notifier@latest", "opencode-tps-meter@latest"],
  "snapshot": false,
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "SUSE Ollama",
      "options": {
        "baseURL": "{file:suse_ollama_url}/v1"
      },
      "models": {
        "qwen3-embedding:4b": { "name": "qwen3-embedding:4b" },
        "qwen2.5-coder:7b-128k": { "name": "qwen2.5-coder:7b-128k" },
        "qwen3:14b-128k": { "name": "qwen3:14b-128k" },
        "qwen3:8b-16k": { "name": "qwen3:8b-16k" },
        "qwen3-coder:30b-32k": { "name": "qwen3-coder:30b-32k" },
        "qwen3-coder:30b": { "name": "qwen3-coder:30b" },
        "qwen3-coder-32k": { "name": "qwen3-coder-32k" },
        "mistral:7b": { "name": "mistral:7b" },
        "qwen2.5-coder:7b": { "name": "qwen2.5-coder:7b" },
        "qwen3:8b": { "name": "qwen3:8b" },
        "qwen3-coder:latest": { "name": "qwen3-coder:latest" },
        "llama3.2:3b": { "name": "llama3.2:3b" },
        "qwen3:14b": { "name": "qwen3:14b" },
        "qwen3.5-35b-a3b-blind:ud-iq3_s.96k": { "name": "qwen3.5-35b-a3b-blind:ud-iq3_s.96k" }
      }
    },
    "ollama_local": {
        "npm": "@ai-sdk/openai-compatible",
        "name": "Ollama (local)",
        "options": {
            "baseURL": "http://localhost:11434/v1",
            "timeout": 1200000,
            "chunkTimeout": 600000
        },
        "models": {
            "qwen3.5:9b": { "name": "(broken tool calls, try qwen3.5:9b-fix-tools.96k) qwen3.5:9b" },
            "qwen3.5-9B-Claude-4.6-HighIQ-INSTRUCT.Q8_0:latest": { "name": "(does not support tools) qwen3.5-9B-Claude-4.6-HighIQ-INSTRUCT.Q8_0:latest" },
            "huggingface.co/unsloth/Qwen3-Coder-30B-A3B-Instruct-GGUF:65k": { "name": "Qwen3-Coder-30B-A3B-Instruct (GGUF)" },
            "Qwen3-Coder-30B-16k:latest": { "name": "Qwen3 Coder 30B 16k" },
            "qwen3-coder-next:ud-q2_k_xl.64k.fix_tools": { "name": "qwn3-cder-nxt.ud-q2_k_xl.64k.fix_tools" },
            "qwen3.5-35b-a3b-blind:ud-iq3_s.96k": { "name": "qwen3.5-35b-a3b-blind:ud-iq3_s.96k" },
            "qwen3.5:9b-fix-tools.96k": { "name": "qwen3.5:9b-fix-tools.96k" }
        }
    },
    "ollama_okpc4": {
        "npm": "@ai-sdk/openai-compatible",
        "name": "Ollama (okpc4)",
        "options": {
            "baseURL": "http://okpc4.fritz.box:11434/v1",
            "timeout": 600000,
            "chunkTimeout": 600000
        },
        "models": {
            "hf.co/unsloth/Qwen3-Coder-Next-GGUF:Q4_K_M": { "name": "(no tools support) qwen3-coder-next" },
            "qwen3-coder:30b": { "name": "(slow but good) qwen3-coder:30b" },
            "qwen3-coder-30b-a3b-instruct-gguf-ud-q4_k_m-96k": { "name": "(faster than qwen3-coder default but did not call gh tool) qwen3-coder-30b-a3b-instruct-gguf-ud-q4_k_m-96k:latest" },
            "qwen3.5:9b-q8_0-128k": { "name": "(broken tool calling, XML) qwen3.5:9b-q8_0" },
            "qwen3.5:9b-q8_0-32k": { "name": "(broken tool calling, XML) qwen3.5:9b-q8_0-32k" },
            "qwen3.5:9b-q8_0-64k": { "name": "(broken tool calling, XML) qwen3.5:9b-q8_0-64k" },
            "qwen3.5:9b-q8_0-96k": {
                "name": "(broken tool calling, XML) qwen3.5:9b-q8_0-96k",
                "reasoning": false,
                "think": false,
                "tool_call": true

            },
            "qwen3.5:9b-q8_0-96k-tweaked-parser-and-parms": { "name": "(broken tool calling, XML) qwen3.5:9b-q8_0-96k-tweaked-parser-and-parms" },
            "qwen3.5:27b-q4_K_M": { "name": "(very slow) qwen3.5:27b-q4_K_M" },
            "qwen3.5-27b-claude-4.6-opus-reasoning-distilled-blind.q4_k_m-96k": { "name": "(medium-slow speed) qwen3.5-27b-cl-rsnng-dstlld-blnd.q4_k_m-96k" },
            "qwen3.5-27b-claude-4.6-opus-reasoning-distilled-blind.q3_k_m-96k": { "name": "(medium speed) qwen3.5-27b-cl-rsnng-dstlled-bind.q3_k_m-96k" },
            "hf.co/unsloth/Qwen3.5-35B-A3B-GGUF:UD-IQ3_S": { "name": "hf.co/unsloth/Qwen3.5-35B-A3B-GGUF:UD-IQ3_S" },
            "qwen3.5-9b-cl-rsnng-dstlld-blnd.q8-96k": { "name": "(fast, sometimes broken tool calling, XML) qwen3.5-9b-cl-rsnng-dstlld-blnd.q8-96k" },
            "qwen3.5-9b-gm-rsng-dstlld.Q8_0.96k": { "name": "(no tools support) qwen3.5-9b-gm-rsng-dstlld.Q8_0.96k" },
            "qwen3.5-9b-gm-rsng-dstlld.Q8_0.96k-ollama-prompt": { "name": "qwen3.5-9b-gm-rsng-dstlld.Q8_0.96k-ollama-prompt" },
            "qwen3.5-9b-claude-4.6-highiq-instruct.q8_0-32k": {
                "name": "(does not support tools) qwen3.5-9b-claude-4.6-highiq-instruct.q8_0-32k",
                "tools": true
            },
            "qwen3-coder-next@q2_k_xl": { "name": "qwen3-coder-next:ud-q2_k_xl.64k.fix_tools" }
        }
    },
    "lmstudio_okpc4": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (okpc4)",
      "options": {
        "baseURL": "http://okpc4.fritz.box:1234/v1",
        "timeout": 600000,
        "chunkTimeout": 600000,
        "apiKey": "{file:~/.lmstudio_okpc4_token}"
      },
      "models": {
          "qwen/qwen3.5-35b-a3b": { "name": "(ok) qwen/qwen3.5-35b-a3b" },
          "qwen3-coder-next@q4_k_s": { "name": "(slow) qwen3-coder-next@q4_k_s" },
          "qwen3-coder-next@q3_k_m": { "name": "(slow) qwen3-coder-next@q3_k_m" },
          "qwen3-coder-next@q2_k_xl": { "name": "qwen3-coder-next@q2_k_xl" },
          "qwen/qwen3.5-9b": { "name": "qwen/qwen3.5-9b" }
      }
    },
    "google": {
        "options": {
            "projectId": "{file:~/.suse_gemini_cloud_project_id}"
        }
    }
  }
}
